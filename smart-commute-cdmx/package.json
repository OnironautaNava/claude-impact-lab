{
  "name": "smart-commute-cdmx",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts vitest.config.ts eslint.config.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:single": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:data": "node scripts/generate-mvp-data.mjs",
    "generate:sprint1": "node scripts/generate-sprint1-artifacts.mjs",
    "generate:multimodal": "python scripts/generate_multimodal_data.py"
  },
  "dependencies": {
    "maplibre-gl": "4.7.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/geojson": "7946.0.15",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^5.4.21",
    "vitest": "^3.1.2"
  }
